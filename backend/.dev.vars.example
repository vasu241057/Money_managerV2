# Copy to backend/.dev.vars for local wrangler dev.
# Do not commit backend/.dev.vars.

# Required secret in all environments.
SUPABASE_POOLER_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=

# OAuth and AI secrets (used in upcoming milestones).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
OPENROUTER_API_KEY=

# Optional overrides for local testing.
APP_NAME=money-manager-backend
APP_VERSION=0.1.0
NODE_ENV=development
DB_MAX_CONNECTIONS=5
DB_CONNECT_TIMEOUT_SECONDS=5
CLERK_JWT_CLOCK_SKEW_SECONDS=60
